{
  "name": "sdc-library-storybook",
  "version": "0.1.0",
  "private": true,
  "description": "Storybook 8 setup for the sdc_library Drupal components.",
  "type": "module",
  "scripts": {
    "storybook": "storybook dev -p 6006",
    "build": "storybook build",
    "lint": "prettier --check 'stories/**/*.{js,mjs}' '.storybook/**/*.{js,mjs}'",
    "format": "prettier --write 'stories/**/*.{js,mjs}' '.storybook/**/*.{js,mjs}'"
  },
  "devDependencies": {
    "@storybook/addon-a11y": "^8.4.0",
    "@storybook/addon-essentials": "^8.4.0",
    "@storybook/addon-interactions": "^8.4.0",
    "@storybook/html": "^8.4.0",
    "@storybook/html-vite": "^8.4.0",
    "prettier": "^3.3.3",
    "storybook": "^8.4.0",
    "vite": "^5.4.0"
  }
}
