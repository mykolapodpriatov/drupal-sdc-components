{#
/**
 * @file
 * Tabs component.
 *
 * The component renders a real ARIA tablist. Without JS every panel is
 * visible (no information hiding). With JS, only the active panel shows
 * and arrow keys move focus between tabs.
 */
#}
{% set initial = initial|default(0) %}
{% set uid = 'sdc-tabs-' ~ random() %}

<div class="c-tabs" data-component="tabs" data-initial="{{ initial }}">
  <div class="c-tabs__list" role="tablist" aria-orientation="horizontal">
    {% for tab in tabs %}
      {% set is_active = loop.index0 == initial %}
      <button
        type="button"
        class="c-tabs__tab{{ is_active ? ' is-active' : '' }}"
        id="{{ uid }}-tab-{{ loop.index0 }}"
        role="tab"
        aria-selected="{{ is_active ? 'true' : 'false' }}"
        aria-controls="{{ tab.panel_id }}"
        tabindex="{{ is_active ? '0' : '-1' }}"
        data-tab-index="{{ loop.index0 }}"
        data-panel-id="{{ tab.panel_id }}"
      >
        {{ tab.label }}
      </button>
    {% endfor %}
  </div>

  <div class="c-tabs__panels">
    {% block panels %}{% endblock %}
  </div>
</div>
