{#
/**
 * @file
 * Hero component.
 *
 * Three layouts:
 *   - full     — image as background, text overlaid.
 *   - split    — image and text side-by-side (default).
 *   - compact  — text-only, reduced height.
 */
#}
{% set variant = variant|default('split') %}
{% set classes = [
  'c-hero',
  'c-hero--' ~ variant,
  image_src ? 'c-hero--has-image' : 'c-hero--no-image',
] %}

<header class="{{ classes|join(' ') }}" data-component="hero" data-variant="{{ variant }}">
  {% if image_src and variant != 'compact' %}
    <div class="c-hero__media">
      <picture class="c-hero__picture">
        {# Themes can extend this by overriding the template and adding <source> elements via picture sources. #}
        <img
          class="c-hero__image"
          src="{{ image_src }}"
          alt="{{ image_alt|default('') }}"
          loading="eager"
          fetchpriority="high"
          decoding="async"
        />
      </picture>
    </div>
  {% endif %}

  <div class="c-hero__content">
    <div class="c-hero__inner">
      <h1 class="c-hero__heading">{{ heading }}</h1>

      {% if subheading %}
        <p class="c-hero__subheading">{{ subheading }}</p>
      {% endif %}

      {% if cta_label and cta_url %}
        <p class="c-hero__actions">
          <a class="c-hero__cta" href="{{ cta_url }}">
            {{ cta_label }}
            <svg
              class="c-hero__cta-arrow"
              width="16"
              height="16"
              viewBox="0 0 16 16"
              aria-hidden="true"
              focusable="false"
            >
              <path d="M3 8h10m-4-4l4 4-4 4" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        </p>
      {% endif %}
    </div>
  </div>
</header>
