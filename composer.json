{
    "name": "mykolapodpriatov/drupal-sdc-components",
    "description": "Reusable Single Directory Components library for Drupal 10.3+/11 — Card, Accordion, Tabs, Hero.",
    "type": "drupal-module",
    "license": "MIT",
    "keywords": ["drupal", "sdc", "single-directory-components", "components", "ui", "drupal-module"],
    "homepage": "https://github.com/mykolapodpriatov/drupal-sdc-components",
    "authors": [
        {
            "name": "Mykola Podpriatov",
            "role": "Maintainer"
        }
    ],
    "minimum-stability": "stable",
    "require": {
        "php": ">=8.3",
        "drupal/core": "^10.3 || ^11"
    },
    "require-dev": {
        "drupal/core-dev": "^10.3 || ^11",
        "squizlabs/php_codesniffer": "^3.10",
        "drupal/coder": "^8.3"
    },
    "suggest": {
        "drupal/paragraphs": "For the paragraph integration examples shipped under examples/."
    },
    "extra": {
        "drupal-scaffold": {
            "locations": {
                "web-root": "./"
            }
        }
    },
    "scripts": {
        "phpcs": "phpcs --standard=Drupal,DrupalPractice --extensions=php,module,inc,install,test,profile,theme sdc_library.module",
        "phpcbf": "phpcbf --standard=Drupal,DrupalPractice --extensions=php,module,inc,install,test,profile,theme sdc_library.module"
    }
}
